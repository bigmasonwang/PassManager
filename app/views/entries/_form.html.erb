<%= form_with(model: @entry, local: true) do |f| %>
  <% if @entry.errors.any? %>
    <div class="alert alert-danger">
      <h4><%= pluralize(@entry.errors.count, "error") %> prohibited this entry from being saved:</h4>
      <ul>
        <% @entry.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>
  <div class="mb-3">
    <%= f.label :name, class: "form-label" %>
    <%= f.text_field :name, class: "form-control", placeholder: "Enter entry name" %>
  </div>
  <div class="mb-3">
    <%= f.label :url, class: "form-label" %>
    <%= f.url_field :url, class: "form-control", placeholder: "https://example.com" %>
  </div>
  <div class="mb-3">
    <%= f.label :username, class: "form-label" %>
    <%= f.text_field :username, class: "form-control", placeholder: "Enter username" %>
  </div>
  <div class="mb-4">
    <%= f.label :password, class: "form-label" %>
    <%= f.password_field :password, class: "form-control", placeholder: "Enter password" %>
  </div>
  <div class="d-grid gap-2">
    <%= f.submit submit_text, class: "btn btn-primary" %>
    <%= link_to "Back", entries_path, class: "btn btn-outline-secondary" %>
  </div>
<% end %> 