<div class="container py-5">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h2 mb-0">Password Entries</h1>
    <%= link_to new_entry_path, class: "btn btn-primary" do %>
      <i class="bi bi-plus-lg me-2"></i>New Entry
    <% end %>
  </div>
  <% if @entries.any? %>
    <div class="card shadow-sm">
      <div class="row">
        <div class="col-md-4">
          <div class="list-group list-group-flush rounded h-100 border-end">
            <% @entries.each do |entry| %>
              <%= link_to edit_entry_path(entry), class: "list-group-item list-group-item-action d-flex align-items-center" do %>
                <% if entry.url.present? %>
                  <%= image_tag "https://www.google.com/s2/favicons?domain=#{URI.parse(entry.url).host}&sz=32", 
                  class: "me-2", 
                  width: 16, 
                  height: 16, 
                  onerror: "this.style.display='none'" %>
                <% end %>
                <%= entry.name %>
              <% end %>
            <% end %>
          </div>
        </div>
        <div class="col-md-8">
          <%= render "entry", entry: @entries.first %>
        </div>
      </div>
    </div>
  <% else %>
    <div class="text-center py-5">
      <div class="mb-3">
        <i class="bi bi-shield-lock text-muted" style="font-size: 3rem;"></i>
      </div>
      <h3 class="h4 text-muted mb-3">No entries yet</h3>
      <p class="text-muted mb-4">Start by adding your first password entry</p>
      <%= link_to new_entry_path, class: "btn btn-primary" do %>
        <i class="bi bi-plus-lg me-2"></i>Add First Entry
      <% end %>
    </div>
  <% end %>
</div>
