<div class="container py-5">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h2 mb-0">Password Entries</h1>
    <%= link_to new_entry_path, class: "btn btn-primary" do %>
      <i class="bi bi-plus-lg me-2"></i>New Entry
    <% end %>
  </div>
  <% if @entries.any? %>
    <div class="card shadow-sm">
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
          <thead class="bg-light">
            <tr>
              <th>Name</th>
              <th>URL</th>
              <th>Username</th>
              <th>Password</th>
              <th class="text-end">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% @entries.each do |entry| %>
              <tr>
                <td><%= entry.name %></td>
                <td>
                  <% if entry.url.present? %>
                    <%= link_to entry.url, entry.url, target: "_blank", class: "text-decoration-none" %>
                  <% end %>
                </td>
                <td><%= entry.username %></td>
                <td><%= entry.password %></td>
                <td class="text-end">
                  <div class="btn-group">
                    <%= link_to edit_entry_path(entry), class: "btn btn-sm btn-outline-primary" do %>
                      <i class="bi bi-pencil"></i>
                    <% end %>
                    <%= button_to entry_path(entry), 
                                method: :delete, 
                                class: "btn btn-sm btn-outline-danger",
                                form: { data: { turbo_confirm: "Are you sure you want to delete this entry?" } } do %>
                      <i class="bi bi-trash"></i>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  <% else %>
    <div class="text-center py-5">
      <div class="mb-3">
        <i class="bi bi-shield-lock text-muted" style="font-size: 3rem;"></i>
      </div>
      <h3 class="h4 text-muted mb-3">No entries yet</h3>
      <p class="text-muted mb-4">Start by adding your first password entry</p>
      <%= link_to new_entry_path, class: "btn btn-primary" do %>
        <i class="bi bi-plus-lg me-2"></i>Add First Entry
      <% end %>
    </div>
  <% end %>
</div>
